#!/bin/bash -e

# Verify <file> against <expected> sha256. Prefer sha256sum (Linux/coreutils);
# fall back to shasum, which is always present on macOS even when the coreutils
# gnubin dir is not on PATH (run_once_003 installs coreutils as gsha256sum).
verify_sha256() {  # <expected> <file>
  if command -v sha256sum >/dev/null 2>&1; then
    echo "$1  $2" | sha256sum -c -
  else
    echo "$1  $2" | shasum -a 256 -c -
  fi
}

# From: https://krew.sigs.k8s.io/docs/user-guide/setup/install/

echo "Installing https://cli.github.com/"

version="2.95.0"
unamestr=$(uname)
machinestr=$(uname -m)

# Use mktemp in a way that works on both macOS and Linux
if [[ "$unamestr" == 'Darwin' ]]; then
    tmp_dir=$(mktemp -d -t github-cli.XXX)
else
    tmp_dir=$(mktemp --directory --tmpdir=/tmp github-cli.XXX)
fi

# Set OS architecture, file extension, and pinned checksum appropriately.
# To upgrade: bump the version and update all four sha256 values from
# https://github.com/cli/cli/releases/download/v<ver>/gh_<ver>_checksums.txt
if [[ "$unamestr" == 'Darwin' ]]; then
    file_ext="zip"
    if [[ "$machinestr" == 'arm64' ]]; then
        os_arch="macOS_arm64"
        sha256="3677f9c27965825f9c7d50395473c134edaea4b484373ef6b25de653570a0489"
    else
        os_arch="macOS_amd64"
        sha256="985707e9ac60c95ed51cddd808c338b481abe69fffa77e9d6547c3750045f77e"
    fi
elif [[ "$unamestr" == 'Linux' ]]; then
    file_ext="tar.gz"
    if [[ "$machinestr" == 'aarch64' ]]; then
        os_arch="linux_arm64"
        sha256="d41e0b3b6218e5741c8bb4db39b16e53a59e0e06299a8489bd38f623ef7ebaae"
    else
        os_arch="linux_amd64"
        sha256="25d1e4729e8808c9ed3d613e96ebd3f3e44446f2d368c89d878a71a36ddb3d8c"
    fi
else
    echo "I don't support installing in this OS yet!"
    exit 1
fi

url="https://github.com/cli/cli/releases/download/v${version}/gh_${version}_${os_arch}.${file_ext}"
archive_path="${tmp_dir}/archive.${file_ext}"

echo "Downloading from: $url"
curl -L "$url" -o "$archive_path"
verify_sha256 "${sha256}" "${archive_path}"
cd "$tmp_dir"
pwd
ls -l

# Extract based on the file extension
if [[ "$file_ext" == "zip" ]]; then
    unzip "$archive_path"
    # Find the directory that was created after extraction
    extracted_dir=$(find . -type d -name "gh_*" | head -1)
    if [[ -n "$extracted_dir" ]]; then
        cd "$extracted_dir"
    fi
else
    tar --strip-components=1 -xzvf "$archive_path"
fi

rm -f "$archive_path"
ls -l

# Create destination directory if it doesn't exist
mkdir -p ~/.local/opt/github-cli
rm -rf ~/.local/opt/github-cli/*
mv ./* ~/.local/opt/github-cli/

echo "GitHub CLI installed successfully to ~/.local/opt/github-cli/"
exit 0
