#!/bin/bash -e

# Verify <file> against <expected> sha256. Prefer sha256sum (Linux/coreutils);
# fall back to shasum, which is always present on macOS even when the coreutils
# gnubin dir is not on PATH (run_once_003 installs coreutils as gsha256sum).
verify_sha256() {  # <expected> <file>
  if command -v sha256sum >/dev/null 2>&1; then
    echo "$1  $2" | sha256sum -c -
  else
    echo "$1  $2" | shasum -a 256 -c -
  fi
}

echo "Installing ruff"

unamestr=$(uname)

if [[ "$unamestr" == 'Darwin' ]]; then
    brew install ruff
elif [[ "$unamestr" == 'Linux' ]]; then
    # Pinned release + hardcoded checksum. Installs to ~/bin (no sudo).
    # To upgrade: bump the version and update the sha256 from
    # https://github.com/astral-sh/ruff/releases/download/<ver>/<archive>.sha256
    ruff_version="0.15.19"
    case "$(uname -m)" in
        x86_64)        archive="ruff-x86_64-unknown-linux-gnu.tar.gz"; ruff_sha256="0bfabff71f317e0e3b8c363043b888f045eff092073d5d9bd0ac7f8ede465711" ;;
        aarch64|arm64) archive="ruff-aarch64-unknown-linux-gnu.tar.gz"; ruff_sha256="b00f8c17424c0abea8f87ca52880b864d10ae8e5c5d09ee61730a80ee3874a97" ;;
        *) echo "ERROR: unsupported architecture $(uname -m)" >&2; exit 1 ;;
    esac
    url="https://github.com/astral-sh/ruff/releases/download/${ruff_version}/${archive}"

    tmp_dir="$(mktemp -d)"
    trap 'rm -rf "$tmp_dir"' EXIT
    curl -fLsS "$url" -o "$tmp_dir/$archive"
    verify_sha256 "${ruff_sha256}" "${tmp_dir}/${archive}"

    tar -xzf "$tmp_dir/$archive" -C "$tmp_dir"
    mkdir -p "$HOME/bin"
    find "$tmp_dir" -type f -name ruff -exec mv {} "$HOME/bin/ruff" \;
    chmod +x "$HOME/bin/ruff"
else
    echo "ERROR: I don't support installation for this OS yet!"
    exit 1
fi
