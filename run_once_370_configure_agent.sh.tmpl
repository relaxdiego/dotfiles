{{ if and (hasKey . "agent") .agent -}}
#!/bin/bash -e

# One-time setup for agent machines.

# 1. Generate a commit-signing SSH key. Upload this to GitHub as a
#    "Signing Key" (NOT an "Authentication Key") so that it can only
#    sign commits. It cannot be used to push, pull, or log in.
mkdir -p ~/.ssh
chmod 700 ~/.ssh
if [ ! -f ~/.ssh/agent_signing_key ]; then
    echo "Generating commit signing key"
    ssh-keygen -t ed25519 -f ~/.ssh/agent_signing_key -N "" -C "agent-signing-{{ .chezmoi.hostname }}"
fi

# 2. Print the steps that cannot be automated.
cat <<EOF

=====================================================================
Agent machine: remaining manual steps
=====================================================================
1. Give the agent one fine-grained PAT per GitHub org it should reach.
   Put them in ~/.config/gh-org-tokens (readable only by you), one
   "<org>=<token>" per line, plus an optional "default=<token>" used
   outside any repo:

       install -m 600 /dev/null ~/.config/gh-org-tokens
       \$EDITOR ~/.config/gh-org-tokens        # e.g.:
       #   my-org=github_pat_xxx
       #   other-org=github_pat_yyy
       #   default=github_pat_xxx

   git then picks the right token per repo automatically (via
   ~/.local/bin/git-credential-gh-org). Authenticate gh once so it
   works outside a repo; do NOT run 'gh auth setup-git' — the per-org
   helper already owns git's HTTPS credentials:

       gh auth login    # GitHub.com > HTTPS > paste your default-org PAT

2. Upload the signing key below to https://github.com/settings/keys
   Choose key type "Signing Key" (NOT "Authentication Key"):

$(sed 's/^/       /' ~/.ssh/agent_signing_key.pub)
=====================================================================

EOF
{{ end -}}
