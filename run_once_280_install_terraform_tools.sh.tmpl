#!/bin/bash -e

# Verify <file> against <expected> sha256. Prefer sha256sum (Linux/coreutils);
# fall back to shasum, which is always present on macOS even when the coreutils
# gnubin dir is not on PATH (run_once_003 installs coreutils as gsha256sum).
verify_sha256() {  # <expected> <file>
  if command -v sha256sum >/dev/null 2>&1; then
    echo "$1  $2" | sha256sum -c -
  else
    echo "$1  $2" | shasum -a 256 -c -
  fi
}

echo "Installing tflint"

unamestr=$(uname)

if [[ "$unamestr" == 'Darwin' ]]; then
    brew install tflint
elif [[ "$unamestr" == 'Linux' ]]; then
    # Pinned release + hardcoded checksum. Installs to ~/bin (no sudo).
    # To upgrade: bump the version and update the sha256 from the
    # checksums.txt of https://github.com/terraform-linters/tflint/releases
    tflint_version="0.63.1"
    case "$(uname -m)" in
        x86_64)        archive="tflint_linux_amd64.zip"; tflint_sha256="8441a7d97df20431f19c9b9d27ff4c63e308c964e86660bc7cc0cf7bbe0725e8" ;;
        aarch64|arm64) archive="tflint_linux_arm64.zip"; tflint_sha256="6d858ca7f11858c3fe3c5e29cc746823abccb55e2d2e2da130fa7ad7ea4eecb8" ;;
        *) echo "ERROR: unsupported architecture $(uname -m)" >&2; exit 1 ;;
    esac
    url="https://github.com/terraform-linters/tflint/releases/download/v${tflint_version}/${archive}"

    tmp_dir="$(mktemp -d)"
    trap 'rm -rf "$tmp_dir"' EXIT
    curl -fLsS "$url" -o "$tmp_dir/$archive"
    verify_sha256 "${tflint_sha256}" "${tmp_dir}/${archive}"

    unzip -o "$tmp_dir/$archive" -d "$tmp_dir"
    mkdir -p "$HOME/bin"
    mv "$tmp_dir/tflint" "$HOME/bin/tflint"
    chmod +x "$HOME/bin/tflint"
else
    echo "ERROR: I don't support installation for this OS yet!"
    exit 1
fi
