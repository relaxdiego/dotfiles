#!/bin/bash -e

# Verify <file> against <expected> sha256. Prefer sha256sum (Linux/coreutils);
# fall back to shasum, which is always present on macOS even when the coreutils
# gnubin dir is not on PATH (run_once_003 installs coreutils as gsha256sum).
verify_sha256() {  # <expected> <file>
  if command -v sha256sum >/dev/null 2>&1; then
    echo "$1  $2" | sha256sum -c -
  else
    echo "$1  $2" | shasum -a 256 -c -
  fi
}

echo "Installing github.com/stefanlogue/meteor"

if [[ "$(uname)" == "Darwin" ]]; then
    brew tap stefanlogue/tools
    brew install --cask meteor
elif [[ "$(uname)" == "Linux" ]]; then
    # Pinned release + checksum. Installs to ~/bin (no sudo). Homebrew casks
    # don't work on Linux, so grab the prebuilt binary instead. To upgrade:
    # bump the version and update the sha256 values from
    # https://github.com/stefanlogue/meteor/releases/download/v<ver>/meteor_<ver>_checksums.txt
    meteor_version="0.31.0"
    case "$(uname -m)" in
        x86_64)        archive="meteor-linux-amd64.zip"; sha256="5777daa357e5987dbc2d6f2bd0d64d1b908ddcbb7c34deec7401a8c46919417c" ;;
        aarch64|arm64) archive="meteor-linux-arm64.zip"; sha256="c099548092799cb5bb1065d5a78958beaaa8c58d0ce659907566c53246442720" ;;
        *) echo "ERROR: unsupported architecture $(uname -m)" >&2; exit 1 ;;
    esac
    url="https://github.com/stefanlogue/meteor/releases/download/v${meteor_version}/${archive}"

    tmp_dir="$(mktemp -d)"
    trap 'rm -rf "$tmp_dir"' EXIT
    curl -fLsS "$url" -o "$tmp_dir/$archive"
    verify_sha256 "${sha256}" "${tmp_dir}/${archive}"

    unzip -o "$tmp_dir/$archive" -d "$tmp_dir"
    mkdir -p "$HOME/bin"
    mv "$tmp_dir/meteor" "$HOME/bin/meteor"
    chmod +x "$HOME/bin/meteor"
else
    echo "ERROR: I don't support installation for this OS yet!" >&2
    exit 1
fi
