#!/usr/bin/env bash
set -e

# Verify <file> against <expected> sha256. Prefer sha256sum (Linux/coreutils);
# fall back to shasum, which is always present on macOS even when the coreutils
# gnubin dir is not on PATH (run_once_003 installs coreutils as gsha256sum).
verify_sha256() {  # <expected> <file>
  if command -v sha256sum >/dev/null 2>&1; then
    echo "$1  $2" | sha256sum -c -
  else
    echo "$1  $2" | shasum -a 256 -c -
  fi
}

# Create ~/bin directory if it doesn't exist and add to PATH if needed
mkdir -p ~/bin
export PATH="$HOME/bin:$PATH"

# Determine OS and architecture
OS=$(uname -s | tr '[:upper:]' '[:lower:]')
if [[ "$OS" != "linux" && "$OS" != "darwin" ]]; then
  echo "Error: Unsupported OS. This script works only on Linux or macOS."
  exit 1
fi

# Determine architecture
ARCH=$(uname -m)
if [[ "$ARCH" == "x86_64" ]]; then
  ARCH="amd64"
elif [[ "$ARCH" == "aarch64" || "$ARCH" == "arm64" ]]; then
  ARCH="arm64"
else
  echo "Error: Unsupported architecture. This script works only on x86_64/amd64 or arm64."
  exit 1
fi

echo "Detected: OS=$OS, ARCH=$ARCH"

# Pinned Go version. To upgrade: bump GO_VERSION and update the sha256 values
# from https://go.dev/dl/?mode=json for the matching go<ver>.<os>-<arch>.tar.gz
# files.
GO_VERSION="1.26.4"
echo "Installing Go ${GO_VERSION}"
GO_TARBALL="go${GO_VERSION}.${OS}-${ARCH}.tar.gz"
GO_URL="https://go.dev/dl/${GO_TARBALL}"
case "${OS}-${ARCH}" in
  linux-amd64)  GO_SHA256="1153d3d50e0ac764b447adfe05c2bcf08e889d42a02e0fe0259bd47f6733ad7f" ;;
  linux-arm64)  GO_SHA256="ef758ae7c6cf9267c9c0ef080b8965f453d89ab2d25d9eb22de4405925238768" ;;
  darwin-arm64) GO_SHA256="b62ad2b6d7d2464f12a5bcad7ff47f19d08325773b5efd21610e445a05a9bf53" ;;
  *) echo "Error: no Go checksum pinned for ${OS}-${ARCH}" >&2; exit 1 ;;
esac

echo "Downloading Go from $GO_URL"
TMP_DIR=$(mktemp -d)
curl -L "$GO_URL" -o "$TMP_DIR/$GO_TARBALL"
verify_sha256 "${GO_SHA256}" "$TMP_DIR/$GO_TARBALL"

echo "Extracting Go to temporary location..."
tar -C "$TMP_DIR" -xzf "$TMP_DIR/$GO_TARBALL"

echo "Installing Go to ~/bin..."
# This creates a go directory inside ~/bin with all Go files
cp -rf "$TMP_DIR/go" ~/bin/

# Create symlinks for go executables in ~/bin
ln -sf ~/bin/go/bin/go ~/bin/go
ln -sf ~/bin/go/bin/gofmt ~/bin/gofmt

# Clean up
rm -rf "$TMP_DIR"
echo "Go $GO_VERSION installed successfully in ~/bin"

# Install additional tools
echo "Installing additional Go tools..."

# Install golangci-lint
GOLANGCI_LINT_VERSION="2.12.2"
echo "Installing golangci-lint ${GOLANGCI_LINT_VERSION}"
GOLANGCI_LINT_ARCHIVE="golangci-lint-${GOLANGCI_LINT_VERSION}-${OS}-${ARCH}.tar.gz"
GOLANGCI_LINT_URL="https://github.com/golangci/golangci-lint/releases/download/v${GOLANGCI_LINT_VERSION}/${GOLANGCI_LINT_ARCHIVE}"
# Pinned checksum. To upgrade: bump the version and update the sha256 values from
# golangci-lint-<ver>-checksums.txt in the matching GitHub release.
case "${OS}-${ARCH}" in
  linux-amd64)  GOLANGCI_LINT_SHA256="8df580d2670fed8fa984aac0507099af8df275e665215f5c7a2ae3943893a553" ;;
  linux-arm64)  GOLANGCI_LINT_SHA256="44cd40a8c76c86755375adfeea52cfd3533cb43d7bd647771e0ae065e166df3a" ;;
  darwin-arm64) GOLANGCI_LINT_SHA256="a9c54498731b3128f79e090be6110f3e5fffccc617b08142ed244d4126c73f29" ;;
  *) echo "Error: no golangci-lint checksum pinned for ${OS}-${ARCH}" >&2; exit 1 ;;
esac
TMP_DIR=$(mktemp -d)
curl -L "$GOLANGCI_LINT_URL" -o "$TMP_DIR/$GOLANGCI_LINT_ARCHIVE"
verify_sha256 "${GOLANGCI_LINT_SHA256}" "$TMP_DIR/$GOLANGCI_LINT_ARCHIVE"
tar -C "$TMP_DIR" -xzf "$TMP_DIR/$GOLANGCI_LINT_ARCHIVE"
cp "$TMP_DIR/golangci-lint-${GOLANGCI_LINT_VERSION}-${OS}-${ARCH}/golangci-lint" ~/bin/
rm -rf "$TMP_DIR"

GO_BIN=~/bin/go/bin/go

# Install goimports and gofumpt
export GOBIN=~/bin
export PATH="$GOBIN:$PATH"
echo "Installing https://github.com/mvdan/goimports latest"
$GO_BIN install golang.org/x/tools/cmd/goimports@latest

echo "Installing https://github.com/mvdan/gofumpt latest"
GOFUMPT_VERSION="636d7a7b9ae6db4704a12cd990b57a7c8f0ede78" # v0.6.0
$GO_BIN install mvdan.cc/gofumpt@"${GOFUMPT_VERSION}"

echo "Installation complete. Make sure ~/bin is in your PATH."
echo "You may want to add the following line to your shell profile:"
echo "export PATH=\"\$HOME/bin:\$PATH\""
