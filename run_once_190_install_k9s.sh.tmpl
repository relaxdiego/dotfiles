#!/bin/bash -e

# Verify <file> against <expected> sha256. Prefer sha256sum (Linux/coreutils);
# fall back to shasum, which is always present on macOS even when the coreutils
# gnubin dir is not on PATH (run_once_003 installs coreutils as gsha256sum).
verify_sha256() {  # <expected> <file>
  if command -v sha256sum >/dev/null 2>&1; then
    echo "$1  $2" | sha256sum -c -
  else
    echo "$1  $2" | shasum -a 256 -c -
  fi
}

version="0.27.3"
echo "Installing github.com/derailed/k9s ${version}"

unamestr=$(uname)

if [[ "$unamestr" == 'Darwin' ]]; then
    if hash brew 1>&2>/dev/null; then
        brew install k9s
    elif hash port 1>&2>/dev/null; then
        port install k9s
    else
        echo "ERROR: I don't know what package manager you're using!"
        exit 1
    fi
elif [[ "$unamestr" == 'Linux' ]]; then
    echo "Get the binary from https://github.com/derailed/k9s/releases"
    # Pinned checksum. To upgrade: bump the version above and update the sha256
    # from https://github.com/derailed/k9s/releases/download/v<ver>/checksums.txt
    archive="k9s_Linux_amd64.tar.gz"
    sha256="b0eb5fb0decedbee5b6bd415f72af8ce6135ffb8128f9709bc7adcd5cbfa690b"
    mkdir -p /tmp/k9s
    cd /tmp/k9s
    wget "https://github.com/derailed/k9s/releases/download/v${version}/${archive}"
    verify_sha256 "${sha256}" "${archive}"
    tar -xvf "${archive}"
    mkdir -p ~/bin
    cp k9s ~/bin/
else
    echo "ERROR: I don't support installation for this OS yet!"
    exit 1
fi
