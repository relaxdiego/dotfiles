# Download NerdFonts from https://www.nerdfonts.com to see the
# glyps used in this config.

add_newline = false
command_timeout = 300

format = """
$username\
$hostname\
${custom.repopath}\
$git_branch\
$git_commit\
$git_state\
$git_status\
$docker_context\
$package\
$all\
$status\
$line_break\
$jobs\
$battery\
$time\
$character
"""

[username]
format = "[$user]($style)@"
style_user = "#777777"
style_root = "#c4746e"
{{ if and (hasKey . "agent") .agent -}}
disabled = true
{{- end }}

[hostname]
format = "[$hostname]($style) "
{{ if and (hasKey . "agent") .agent -}}
style = "#ff8700"
{{- else -}}
style = "#777777"
{{- end }}

# Replaced by [custom.repopath], which is bare-worktree aware and shows
# repo/worktree instead of the worktree folder name (e.g. "main").
[directory]
disabled = true
format = "[$path]($style)[$read_only]($read_only_style) "
truncation_length = 8
truncate_to_repo = true
style = "#8ea4a2"

[custom.repopath]
description = "repo/worktree path label (bare-worktree aware)"
command = "~/.config/starship/repo-path.sh"
when = true
shell = ["bash", "--noprofile", "--norc"]
format = "[$output]($style) "
style = "#8ea4a2"

[docker_context]
symbol = "´łč "
format = '[$symbol$context]($style) '
style = "#8ba4b0"

[aws]
symbol = "ţîŻ "
style = "#a6a69c"
format = '[$symbol($profile )(\($region\) )]($style)'

[kubernetes]
symbol = "ţáŁ "
disabled = false
format = '[$symbol$context(\($namespace\))]($style) '

[[kubernetes.contexts]]
context_pattern = 'arn:aws:eks:(?P<var_region>[\w-]+):\d+:cluster/(?P<var_cluster>[\w-]+)$'
context_alias = '$var_cluster.$var_region'

[[kubernetes.contexts]]
context_pattern = '\d+@(?P<var_cluster>[\w-]+)\.(?P<var_region>[\w-]+)\.eksctl.io$'
context_alias = '$var_cluster.$var_region'

[[kubernetes.contexts]]
context_pattern = "dev.*"
style = "#8a9a7b"

[[kubernetes.contexts]]
context_pattern = "staging.*"
style = "#c4b28a"

[[kubernetes.contexts]]
context_pattern = "prod.*"
style = "#c4746e"

[git_branch]
format = "[$symbol$branch]($style) "
symbol = "´Éś "
style = "#a292a3"

[git_status]
ahead = "Ôçí${count}"
diverged = "Ôçí${ahead_count}Ôçú${behind_count}"
behind = "Ôçú${count}"

[package]
format = "[ţČę $version]($style) "
disabled = true

[golang]
format = "[$symbol($version )]($style)"
symbol = "ˇ░čô "
style = "#8ea4a2"

[nodejs]
format = "[$symbol($version )]($style)"
symbol = "ţ┤Ź "
style = "#8a9a7b"

[python]
format = '[$symbol${pyenv_prefix}(${version})]($style)[( $virtualenv) ](bold #6699BB)'
symbol = "ţť╝ "
style = "#c4b28a"

[ruby]
format = "[$symbol($version )]($style)"
symbol = "ţşł "
style = "#c4746e"

[terraform]
format = "[$symbol$version]($style) "
symbol = "ţóŻ "
disabled = true

[cmd_duration]
format = "´öá [$duration]($style) "
# show_milliseconds = true
style = "#669933"

[battery]
full_symbol = "ˇ░ü╣"
charging_symbol = "ˇ░éç "
discharging_symbol = "ˇ░ü╝"

[[battery.display]]
threshold = 20
style = "bold #c4746e"

[character]
success_symbol = "[\\$](bold #8a9a7b)"
error_symbol = "[\\$](bold #c4746e)"

[status]
disabled = false

[helm]
format = "[helm:$version](bold #9999FF) "
disabled = true

[lua]
format = '[$symbol($version )]($style)'
symbol = "ˇ░ó▒ "
style = "#8ba4b0"

[nix_shell]
symbol = "ˇ▒äů "
format = '[$symbol$state(\($name\))]($style) '
style = "#8ba4b0"
disabled = true
