# Download NerdFonts from https://www.nerdfonts.com to see the
# glyps used in this config.

add_newline = false
command_timeout = 300

format = """
$username\
$hostname\
${custom.repopath}\
$git_branch\
$git_commit\
$git_state\
$git_status\
$docker_context\
$package\
$all\
$status\
$line_break\
$jobs\
$battery\
$time\
$character
"""

[username]
format = "[$user]($style)@"
style_user = "#777777"
style_root = "red"

[hostname]
format = "[$hostname]($style) "
{{ if and (hasKey . "agent") .agent -}}
style = "#ff8700"
{{- else -}}
style = "#777777"
{{- end }}

# Replaced by [custom.repopath], which is bare-worktree aware and shows
# repo/worktree instead of the worktree folder name (e.g. "main").
[directory]
disabled = true
format = "[$path]($style)[$read_only]($read_only_style) "
truncation_length = 8
truncate_to_repo = true
style = "cyan"

[custom.repopath]
description = "repo/worktree path label (bare-worktree aware)"
command = "~/.config/starship/repo-path.sh"
when = true
shell = ["bash", "--noprofile", "--norc"]
format = "[$output]($style) "
style = "cyan"

[docker_context]
symbol = "´êş "
format = '[$symbol$context]($style) '
style = "blue"

[aws]
symbol = "¯î¢ "
style = "dimmed"
format = '[$symbol($profile )(\($region\) )]($style)'

[kubernetes]
symbol = "¯áØ "
disabled = false
format = '[$symbol$context(\($namespace\))]($style) '

[[kubernetes.contexts]]
context_pattern = 'arn:aws:eks:(?P<var_region>[\w-]+):\d+:cluster/(?P<var_cluster>[\w-]+)$'
context_alias = '$var_cluster.$var_region'

[[kubernetes.contexts]]
context_pattern = '\d+@(?P<var_cluster>[\w-]+)\.(?P<var_region>[\w-]+)\.eksctl.io$'
context_alias = '$var_cluster.$var_region'

[[kubernetes.contexts]]
context_pattern = "dev.*"
style = "green"

[[kubernetes.contexts]]
context_pattern = "staging.*"
style = "yellow"

[[kubernetes.contexts]]
context_pattern = "prod.*"
style = "red"

[git_branch]
format = "[$symbol$branch]($style) "
symbol = "´Éİ "
style = "purple"

[git_status]
ahead = "Ôçí${count}"
diverged = "Ôçí${ahead_count}Ôçú${behind_count}"
behind = "Ôçú${count}"

[package]
format = "[¯¼® $version]($style) "
disabled = true

[golang]
format = "[$symbol($version )]($style)"
symbol = "¾░şô "
style = "cyan"

[nodejs]
format = "[$symbol($version )]($style)"
symbol = "¯┤ı "
style = "green"

[python]
format = '[$symbol${pyenv_prefix}(${version})]($style)[( $virtualenv) ](bold #6699BB)'
symbol = "¯£╝ "
style = "yellow"

[ruby]
format = "[$symbol($version )]($style)"
symbol = "¯¡ê "
style = "red"

[terraform]
format = "[$symbol$version]($style) "
symbol = "¯ó¢ "
disabled = true

[cmd_duration]
format = "´öá [$duration]($style) "
# show_milliseconds = true
style = "#669933"

[battery]
full_symbol = "¾░ü╣"
charging_symbol = "¾░éç "
discharging_symbol = "¾░ü╝"

[[battery.display]]
threshold = 20
style = "bold red"

[character]
success_symbol = "[\\$](bold green)"
error_symbol = "[\\$](bold red)"

[status]
disabled = false

[helm]
format = "[helm:$version](bold #9999FF) "
disabled = true

[lua]
format = '[$symbol($version )]($style)'
symbol = "¾░ó▒ "
style = "blue"

[nix_shell]
symbol = "¾▒äà "
format = '[$symbol$state(\($name\))]($style) '
style = "blue"
disabled = true
