{{ if and (hasKey . "agent") .agent -}}
#!/usr/bin/env bash
# git-credential-gh-org — hand git the right GitHub token for the repo's org.
#
# Agent machines reach repos across several GitHub orgs. A fine-grained PAT
# can only belong to one org, so we keep one token per org and pick by the
# first path segment of the repo URL (github.com/<org>/<repo>).
#
# Tokens live in ~/.config/gh-org-tokens (mode 600, NOT in the dotfiles repo),
# one "<org>=<token>" per line, plus an optional "default=<token>".
#
# Wired up in ~/.gitconfig under [credential "https://github.com"] with
# useHttpPath = true so git passes the path (and thus the org) to us.
set -euo pipefail

# git calls the helper with get/store/erase. We only answer get; there is
# nothing to cache, so store and erase are no-ops.
[ "${1:-}" = "get" ] || exit 0

tokens_file="${GH_ORG_TOKENS_FILE:-$HOME/.config/gh-org-tokens}"

# Read the credential request (key=value lines, terminated by a blank line).
host=""
path=""
while IFS= read -r line; do
    [ -z "$line" ] && break
    case "$line" in
        host=*) host=${line#host=} ;;
        path=*) path=${line#path=} ;;
    esac
done

# Only speak for github.com; let git fall through for anything else.
[ "$host" = "github.com" ] || exit 0

if [ ! -f "$tokens_file" ]; then
    echo "git-credential-gh-org: $tokens_file is missing" >&2
    exit 0
fi

org=${path%%/*}

# Print the token for key $1 from the tokens file, if present.
lookup() {
    local key val
    while IFS='=' read -r key val; do
        case "$key" in ''|\#*) continue ;; esac
        if [ "$key" = "$1" ]; then
            printf '%s' "$val"
            return 0
        fi
    done < "$tokens_file"
    return 1
}

token=$(lookup "$org" || true)
[ -n "$token" ] || token=$(lookup default || true)

if [ -z "$token" ]; then
    orgs=$(grep -oE '^[^=#[:space:]]+' "$tokens_file" | grep -vx default | paste -sd ', ' - || true)
    echo "git-credential-gh-org: no token for org '$org' in $tokens_file (tokens exist for: $orgs)" >&2
    echo "git-credential-gh-org: see ~/.local/share/agent-docs/github-auth.md" >&2
    exit 0
fi

# Any non-empty username works with a PAT; use the configured GitHub user.
printf 'username=%s\n' '{{ .github_username }}'
printf 'password=%s\n' "$token"
{{ end -}}
