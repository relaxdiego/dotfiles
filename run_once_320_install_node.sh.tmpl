#!/bin/bash -e

# Verify <file> against <expected> sha256. Prefer sha256sum (Linux/coreutils);
# fall back to shasum, which is always present on macOS even when the coreutils
# gnubin dir is not on PATH (run_once_003 installs coreutils as gsha256sum).
verify_sha256() {  # <expected> <file>
  if command -v sha256sum >/dev/null 2>&1; then
    echo "$1  $2" | sha256sum -c -
  else
    echo "$1  $2" | shasum -a 256 -c -
  fi
}

echo "Node.js"

# Backup ~/.bashrc before installer execution
cp ~/.bashrc ~/.bashrc.87cce59.backup
# installs nvm (Node Version Manager). The installer is pinned to git tag
# v0.40.5, so its bytes are immutable; verify the sha256 before running it.
# To upgrade: bump the tag and update the sha256 of that tag's install.sh.
# v0.40.4 fixed CVE-2026-1665 (command injection via NVM_AUTH_HEADER).
nvm_install_sha256="582070e4c44452c1d8d68e16fc786c2216ecba6bc6bf18dc280a03fdba6ed1a9"
nvm_install_sh="$(mktemp)"
curl -fLsS -o "$nvm_install_sh" https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.5/install.sh
verify_sha256 "${nvm_install_sha256}" "${nvm_install_sh}"
bash "$nvm_install_sh"
rm -f "$nvm_install_sh"
# Restore original bashrc. Settings are in ~/.bashrc.d/100_nvm.bashrc already
mv ~/.bashrc ~/.bashrc.node
mv ~/.bashrc.87cce59.backup ~/.bashrc

source ~/.bashrc.d/100_nvm.bashrc

# download and install Node.js (you may need to restart the terminal)
nvm install 22

# verifies the right Node.js version is in the environment
node -v # should print `v22.x`

# verifies the right npm version is in the environment
npm -v # should print `10.x`
